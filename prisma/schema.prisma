generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ShippingMethod {
  STANDARD
  EXPRESS
  OVERNIGHT
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id           String       @id @default(cuid())
  name         String
  sku          String       @unique
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  available    Int          @default(0)
  reorderPoint Int          @default(0)
  price        Float
  location     String
  images       String[] // Store image file paths
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  stockalert   StockAlert[]
  orderItems   OrderItem[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  type            String // "online" or "shop"
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerAddress String?
  expectedDate    DateTime
  priority        Priority        @default(MEDIUM)
  notes           String?
  paymentMethod   PaymentMethod?
  shippingMethod  ShippingMethod?
  deliveryMethod  DeliveryMethod?
  status          OrderStatus          @default(PENDING) // PENDING, PROCESSING, COMPLETED, CANCELLED
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float // Price at time of order
  createdAt DateTime @default(now())
}

model StockAlert {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String // "LOW_STOCK" or "CRITICAL"
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NavConfig {
  id            String   @id @default(cuid())
  route         String
  role          Role     @default(USER)
  navLinks      Json // Array of { label, href, visible }
  buttons       Json // Array of { label, href, icon, visible }
  showAddButton Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([route, role])
}
